          }
        },
        {
          "@type": "Question",
          "name": "Is there a free plan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. You can start building for free with a generous monthly quota. Paid plans unlock higher limits, priority queue access, team collaboration features, and advanced deployment options."
          }
        }
      ]
    }
  ]
})} />

<!-- ===================== CTA ===================== -->
<CallToAction
  actions={[
    {
      variant: 'primary',
      text: t.cta.primary,
      href: 'https://app.borchani.com/signup',
      target: '_blank',
      icon: 'tabler:rocket',
    },
    {
      variant: 'secondary',
      text: t.cta.secondary,
      href: `${prefix}/pricing`,
      icon: 'tabler:currency-dollar',
    },
  ]}
>
  <Fragment slot="title">
    {t.cta.titleLine1}<br class="hidden md:inline" />
    <span class="text-accent dark:text-white"> {t.cta.titleHighlight}</span>
  </Fragment>

  <Fragment slot="subtitle" set:html={t.cta.subtitle} />
</CallToAction>
