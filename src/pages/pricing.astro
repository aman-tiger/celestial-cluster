---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Pricing  -  Borchani AI App Builder Plans',
  description:
    'Simple pricing for every stage. Start free, upgrade when you need more. No contracts, no hidden fees  -  just build and ship faster with AI.',
  openGraph: {
    type: 'website',
  },
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Pricing"
    title="Pay for what you use. Nothing else."
    subtitle="We kept the pricing simple on purpose. Pick the plan that fits where you are right now  -  you can always change it later."
  />

  <!-- Pricing Widget ******************* -->

  <Prices
    title="Pick your plan"
    subtitle="All plans include the core Borchani experience. Paid plans just remove the limits."
    prices={[
      {
        title: 'Starter',
        subtitle: 'For solo builders and side projects',
        price: 19,
        period: 'per month',
        items: [
          { description: '150 AI credits / month' },
          { description: 'Live sandbox preview' },
          { description: 'Download code as ZIP' },
          { description: 'React 19 + TypeScript + Tailwind' },
          { description: 'Community support' },
        ],
        callToAction: {
          target: '_blank',
          text: 'Get Starter',
          href: 'https://app.borchani.com/api/auth/oauth/google',
        },
      },
      {
        title: 'Pro',
        subtitle: 'For developers who ship every week',
        price: 49,
        period: 'per month',
        items: [
          { description: '500 AI credits / month' },
          { description: 'One-click GitHub export' },
          { description: 'Custom domain deployment' },
          { description: 'Priority build queue' },
          { description: 'TypeScript SDK access' },
          { description: 'Email support (< 24 h)' },
        ],
        callToAction: {
          target: '_blank',
          text: 'Get Pro',
          href: 'https://app.borchani.com/api/auth/oauth/google',
        },
        hasRibbon: true,
        ribbonTitle: 'Most popular',
      },
      {
        title: 'Business',
        subtitle: 'For teams building products together',
        price: 149,
        period: 'per month',
        items: [
          { description: '2,000 AI credits / month' },
          { description: 'Up to 10 seats included' },
          { description: 'Shared workspaces & build history' },
          { description: 'REST API + webhooks' },
          { description: 'SSO & admin controls' },
          { description: 'Priority chat & email support' },
        ],
        callToAction: {
          target: '_blank',
          text: 'Get Business',
          href: 'https://app.borchani.com/api/auth/oauth/google',
        },
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="What every plan comes with"
    subtitle="A few things that are true no matter which tier you're on"
    columns={2}
    items={[
      {
        title: 'Transparent pricing',
        description:
          'The price you see is the price you pay. No surprise charges at the end of the month, ever.',
        icon: 'tabler:flip-vertical',
      },
      {
        title: 'You own the code',
        description:
          'Every line of code Borchani generates belongs to you. Export it, modify it, deploy it anywhere.',
        icon: 'tabler:code',
      },
      {
        title: 'Secure payments',
        description:
          'Payments processed through Stripe. We never store card data on our servers.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Instant access',
        description:
          'Once you subscribe, you get access immediately  -  no waiting period, no manual activation.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Upgrade or downgrade anytime',
        description:
          'Plans are billed monthly. Switch up or down whenever your needs change, no penalties.',
        icon: 'tabler:arrows-exchange',
      },
      {
        title: 'Support on every plan',
        description:
          'Community support on Free, email support on Pro, priority chat + email on Team.',
        icon: 'tabler:headset',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="Up and running in minutes"
    tagline="How it works"
    isReversed={true}
    items={[
      {
        title: 'Pick your plan',
        icon: 'tabler:number-1',
      },
      {
        title: 'Create your account',
        icon: 'tabler:number-2',
      },
      {
        title: 'Enter payment details',
        icon: 'tabler:number-3',
      },
      {
        title: 'Confirm your subscription',
        icon: 'tabler:number-4',
      },
      {
        title: 'Open the builder',
        icon: 'tabler:number-5',
      },
      {
        title: 'Describe your app and hit build',
        icon: 'tabler:number-6',
      },
      {
        title: 'Ship it',
        icon: 'tabler:number-7',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1522542550221-31fd19575a2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=987&q=80',
      alt: 'Getting started with Borchani',
    }}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Pricing questions"
    subtitle="If something still isn't clear after reading this, reach out  -  we'll reply the same day."
    columns={1}
    items={[
      {
        title: 'Does the free plan expire?',
        description:
          'No. The free plan is free forever. You get 10 builds a month and full access to the builder  -  no credit card required to start.',
      },
      {
        title: 'What counts as a "build"?',
        description:
          'A build is one complete generation session  -  from your prompt to a running application. Iterating on an existing build (adding features, fixing things through chat) does not count as a new build.',
      },
      {
        title: 'Can I cancel at any time?',
        description:
          'Yes. Cancel from your account settings anytime. You keep access until the end of the billing period and you will not be charged again.',
      },
      {
        title: 'Do you offer annual billing?',
        description:
          'Yes  -  annual plans come with two months free. Switch to annual billing from your account settings at any time.',
      },
      {
        title: 'Are there any hidden fees?',
        description:
          'None. The monthly price covers everything listed in the plan. The only additional cost would be if you use a custom LLM API key on your own account.',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Ready to build something?"
    subtitle="Start on the free plan today  -  no card required. Upgrade whenever it makes sense for you."
    actions={[
      {
        variant: 'primary',
        text: 'Start building free',
        href: 'https://app.borchani.com/api/auth/oauth/google',
        target: '_blank',
      },
    ]}
  />

  <!-- JSON-LD: PriceSpecification -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Borchani",
    "url": "https://borchani.com",
    "offers": [
      {
        "@type": "Offer",
        "name": "Free",
        "description": "10 AI builds per month, live preview, ZIP download",
        "price": "0",
        "priceCurrency": "USD",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "0",
          "priceCurrency": "USD",
          "unitText": "MONTH"
        }
      },
      {
        "@type": "Offer",
        "name": "Pro",
        "description": "Unlimited builds, GitHub export, custom domain, SDK access",
        "price": "29",
        "priceCurrency": "USD",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "29",
          "priceCurrency": "USD",
          "unitText": "MONTH"
        }
      },
      {
        "@type": "Offer",
        "name": "Team",
        "description": "Everything in Pro plus 10 seats, shared workspaces, API, SSO",
        "price": "99",
        "priceCurrency": "USD",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "99",
          "priceCurrency": "USD",
          "unitText": "MONTH"
        }
      }
    ]
  })} />
</Layout>
