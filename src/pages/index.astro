---
import PageLayout from '~/layouts/PageLayout.astro';
import PromptHero from '~/components/widgets/PromptHero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Borchani — #1 Vibe Coding Platform | Build Full-Stack Apps with AI',
  description:
    'The #1 vibe coding platform. Describe your app, Borchani builds React + TypeScript full-stack in minutes. Live preview, one-click deploy. Free to start.',
  ignoreTitleTemplate: true,
};
---

<PageLayout metadata={metadata}>

  <!-- ─── Hero — prompt input (Lovable / Bolt style) ─── -->
  <PromptHero />

  <!-- ─── Stats strip ─── -->
  <Stats
    stats={[
      { amount: '50K+', title: 'Apps shipped' },
      { amount: '12K+', title: 'Active builders' },
      { amount: '3 min', title: 'From idea to preview' },
      { amount: '99.9%', title: 'Uptime SLA' },
    ]}
  />

  <!-- ─── Core features — benefit-first (Bolt style) ─── -->
  <Features
    id="features"
    tagline="Why Borchani"
    title="Everything you need to ship a real app"
    subtitle="Borchani is the only vibe coding platform that generates production-grade full-stack code — not just a frontend prototype."
    columns={3}
    items={[
      {
        title: 'Ship full-stack apps from one prompt',
        description:
          'Frontend, backend, database schema, and API routes generated together. No gluing three tools into one workflow.',
        icon: 'tabler:layers-union',
      },
      {
        title: 'See it working before you commit',
        description:
          'Your app runs live in a real browser sandbox as Borchani builds. Click every screen, catch gaps early.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Live URL in 30 seconds, free SSL included',
        description:
          'Hit Deploy. Borchani provisions hosting, CDN, and HTTPS automatically. Share a real link in under a minute.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Clean, typed code you actually own',
        description:
          'Every app is React + TypeScript — no proprietary lock-in. Export the full source and deploy it anywhere, anytime.',
        icon: 'tabler:brand-typescript',
      },
      {
        title: 'Auth + Postgres pre-wired, zero setup',
        description:
          'User authentication and a real database are included by default. No third-party accounts, no config files.',
        icon: 'tabler:database',
      },
      {
        title: '"Make the table sortable" — done in seconds',
        description:
          'Keep iterating in plain English after the first build. Borchani applies surgical changes without breaking what works.',
        icon: 'tabler:messages',
      },
    ]}
  />

  <!-- ─── Role-based positioning (Bolt persona section) ─── -->
  <Features2
    tagline="Whatever your role"
    title="Borchani gives you superpowers"
    subtitle="Whether you're a founder, developer, or agency — vibe coding changes how fast you ship."
    items={[
      {
        title: 'For founders',
        description:
          'Go from idea to working MVP in a weekend. Validate before you hire. Ship before you fundraise.',
        icon: 'tabler:rocket',
      },
      {
        title: 'For developers',
        description:
          'Prototype and validate ideas in hours, not sprints. Let Borchani handle boilerplate while you focus on logic.',
        icon: 'tabler:code',
      },
      {
        title: 'For agencies',
        description:
          'Deliver client projects 10× faster. Generate the scaffold in minutes, hand off clean code at the end.',
        icon: 'tabler:briefcase',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- ─── How it works — 3 steps (vibe coding language) ─── -->
  <Steps
    id="how-it-works"
    tagline="How it works"
    title="From idea to deployed app in 3 steps"
    subtitle="No tutorials, no boilerplate. Just describe what you want."
    items={[
      {
        title: 'Step 1: <span class="font-normal">Describe your app</span>',
        description:
          'Type your idea like you\'d explain it to a developer. Borchani handles architecture, routing, and data models automatically.',
        icon: 'tabler:pencil',
      },
      {
        title: 'Step 2: <span class="font-normal">Vibe-check in live preview</span>',
        description:
          'Your app runs in a real browser sandbox. Click through every screen. Refine anything by just asking — "make the navbar sticky", "add a dark mode toggle".',
        icon: 'tabler:eye',
      },
      {
        title: 'Step 3: <span class="font-normal">Ship it</span>',
        description:
          'One click deploys to a live URL with SSL, CDN, and monitoring. Share it with users, investors, or clients immediately.',
        icon: 'tabler:rocket',
      },
    ]}
  />

  <!-- ─── Testimonials ─── -->
  <Testimonials
    title="What builders say about Borchani"
    subtitle="From solo founders to dev teams — real people shipping real products."
    testimonials={[
      {
        testimonial:
          'I launched my SaaS MVP in a weekend. No backend experience, no DevOps. Borchani just handled everything.',
        name: 'Marco R.',
        job: 'Founder, Trackflow',
        image: {
          src: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=200&q=80',
          alt: 'Marco R., founder who shipped his SaaS using Borchani vibe coding',
        },
      },
      {
        testimonial:
          'We replaced a 3-week sprint with a 2-hour Borchani session. The code quality was good enough to ship straight to production.',
        name: 'Aiko T.',
        job: 'Engineering Lead, Stackline',
        image: {
          src: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=200&q=80',
          alt: 'Aiko T., engineering lead who used Borchani to accelerate delivery',
        },
      },
      {
        testimonial:
          'Borchani is the first vibe coding tool where the output is actually maintainable TypeScript. Our devs were happy to take it over.',
        name: 'Daniel K.',
        job: 'CTO, Novu Labs',
        image: {
          src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=200&q=80',
          alt: 'Daniel K., CTO who adopted Borchani for production app development',
        },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Testimonials>

  <!-- ─── FAQs (SEO + FAQPage schema) ─── -->
  <FAQs
    id="faq"
    title="Frequently asked questions"
    subtitle="Everything you need to know before you start building."
    tagline="FAQ"
    classes={{ container: 'max-w-4xl' }}
    items={[
      {
        title: 'What is vibe coding?',
        description:
          'Vibe coding means building software by describing what you want in plain English, letting AI handle the code. Borchani is the most complete vibe coding platform: it generates the full stack, runs a live preview, and deploys with one click.',
        icon: 'tabler:chevrons-right',
      },
      {
        title: 'What is Borchani?',
        description:
          'Borchani is an AI app builder and vibe coding platform that generates production-ready full-stack web applications from plain-English prompts. You describe your idea, Borchani writes React + TypeScript code, wires up a database, and deploys it — no coding required.',
        icon: 'tabler:chevrons-right',
      },
      {
        title: 'How is Borchani different from Lovable or Bolt?',
        description:
          'Borchani focuses on full-stack output quality: typed code, built-in auth, a real Postgres database, and clean exports you can take to any host. No proprietary lock-in — you own the code and can deploy it anywhere.',
        icon: 'tabler:chevrons-right',
      },
      {
        title: 'Do I need to know how to code to use Borchani?',
        description:
          'No. Borchani is designed for founders, designers, and product people. If you can write an email, you can build an app on Borchani. Developers also use it to skip boilerplate and prototype faster.',
        icon: 'tabler:chevrons-right',
      },
      {
        title: 'Can I export and own the source code?',
        description:
          'Yes. Every app you build belongs to you. Export the full React + TypeScript source at any time and deploy it to Vercel, Netlify, or your own server. Borchani never holds your code hostage.',
        icon: 'tabler:chevrons-right',
      },
      {
        title: 'How much does Borchani cost?',
        description:
          'Borchani is free to start — build, preview, and iterate for free. Paid plans add custom domains, higher compute, team collaboration, and priority support. No credit card required to begin.',
        icon: 'tabler:chevrons-right',
      },
    ]}
  />

  <!-- ─── Latest blog posts ─── -->
  <BlogLatestPosts
    id="blog"
    title="Guides, comparisons, and tutorials"
    information="Learn how to build faster with vibe coding, compare AI app builders, and get step-by-step guides for shipping your idea with Borchani."
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </BlogLatestPosts>

  <!-- ─── Final CTA ─── -->
  <CallToAction
    title="Start vibe coding for free"
    subtitle="No credit card. No setup. First app live in under 10 minutes."
    actions={[
      {
        variant: 'primary',
        text: "Build with Borchani — it's free",
        href: 'https://borchani.com/build',
        target: '_blank',
      },
    ]}
  />

</PageLayout>
