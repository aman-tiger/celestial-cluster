---
import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import type { Translations } from '~/i18n/schema';

interface Props {
  t: Translations;
  locale?: string;
  showHero?: boolean;
}

const { t, locale = 'en', showHero = true } = Astro.props;
const prefix = locale === 'en' ? '' : `/${locale}`;

const sdkCode = `import BorchaniClient from '@borchani/sdk';
const client = new BorchaniClient({ apiKey: process.env.BORCHANI_API_KEY });
const app = await client.build('Build a kanban board with drag & drop');
await app.waitUntilReady();
console.log('Live at:', app.previewUrl);`;
---

<!-- ===================== HERO ===================== -->
{!showHero ? null : (
  <Hero
    actions={[
      {
        variant: 'primary',
        text: t.hero.ctaPrimary,
        href: 'https://app.borchani.com/api/auth/oauth/google',
        target: '_blank',
        icon: 'tabler:rocket',
      },
      {
        text: t.hero.ctaSecondary,
        href: '#how-it-works',
        icon: 'tabler:player-play',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&w=2070&q=80',
      alt: 'Borchani AI code generation interface',
    }}
  >
    <Fragment slot="title">
      {t.hero.titleLine1}<br />
      <span class="text-accent dark:text-white highlight">{t.hero.titleHighlight}</span><br />
      {t.hero.titleLine3}
    </Fragment>
    <Fragment slot="subtitle">
      <span class="hidden sm:inline" set:html={t.hero.subtitleDesktop} />
      <span class="block sm:hidden font-bold text-blue-600">{t.hero.subtitleMobile}</span>
    </Fragment>
  </Hero>
)}

<!-- Social proof strip -->
<Note title={t.note.trusted} description={t.note.stats} />

<!-- ===================== FEATURES ===================== -->
<Features
  id="features"
  tagline={t.features.tagline}
  title={t.features.title}
  subtitle={t.features.subtitle}
  items={[
    {
      title: t.features.aiCode.title,
      description: t.features.aiCode.description,
      icon: 'tabler:brain',
    },
    {
      title: t.features.livePreview.title,
      description: t.features.livePreview.description,
      icon: 'tabler:eye',
    },
    {
      title: t.features.iteration.title,
      description: t.features.iteration.description,
      icon: 'tabler:message-circle',
    },
    {
      title: t.features.stack.title,
      description: t.features.stack.description,
      icon: 'tabler:stack-2',
    },
    {
      title: t.features.deploy.title,
      description: t.features.deploy.description,
      icon: 'tabler:cloud-upload',
    },
    {
      title: t.features.security.title,
      description: t.features.security.description,
      icon: 'tabler:shield-check',
    },
  ]}
/>

<!-- ===================== HOW IT WORKS ===================== -->
<Steps
  id="how-it-works"
  title={t.steps.title}
  items={[
    {
      title: t.steps.step1.title,
      description: t.steps.step1.description,
      icon: 'tabler:message',
    },
    {
      title: t.steps.step2.title,
      description: t.steps.step2.description,
      icon: 'tabler:code',
    },
    {
      title: t.steps.step3.title,
      description: t.steps.step3.description,
      icon: 'tabler:rocket',
    },
    {
      title: t.steps.done,
      icon: 'tabler:check',
    },
  ]}
  image={{
    src: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=2015&q=80',
    alt: 'Borchani build process',
  }}
/>

<!-- ===================== TECH STACK ===================== -->
<Content
  isReversed
  tagline={t.techStack.tagline}
  title={t.techStack.title}
  items={[
    {
      title: t.techStack.modern.title,
      description: t.techStack.modern.description,
    },
    {
      title: t.techStack.edge.title,
      description: t.techStack.edge.description,
    },
    {
      title: t.techStack.realtime.title,
      description: t.techStack.realtime.description,
    },
  ]}
  image={{
    src: 'https://images.unsplash.com/photo-1555066931-4365d14bab5c?auto=format&fit=crop&w=2070&q=80',
    alt: 'Modern tech stack',
  }}
>
  <Fragment slot="content">
    <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
      {t.techStack.contentTitle}
    </h3>
    {t.techStack.contentSubtitle}
  </Fragment>

  <Fragment slot="bg">
    <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
  </Fragment>
</Content>

<!-- ===================== SDK ===================== -->
<Content
  id="sdk"
  isAfterContent
  items={[
    {
      title: t.sdk.typed.title,
      description: t.sdk.typed.description,
    },
    {
      title: t.sdk.session.title,
      description: t.sdk.session.description,
    },
    {
      title: t.sdk.cicd.title,
      description: t.sdk.cicd.description,
    },
  ]}
  image={{
    src: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=2070&q=80',
    alt: 'Borchani SDK integration',
  }}
>
  <Fragment slot="content">
    <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-4">
      {t.sdk.contentTitle}
    </h3>
    <pre
      class="bg-slate-900 text-green-400 p-4 rounded-lg text-sm overflow-x-auto leading-relaxed"
      set:html={sdkCode
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')}
    ></pre>
  </Fragment>

  <Fragment slot="bg">
    <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
  </Fragment>
</Content>

<!-- ===================== USE CASES ===================== -->
<Features2
  id="use-cases"
  title={t.useCases.title}
  subtitle={t.useCases.subtitle}
  tagline={t.useCases.tagline}
  items={[
    {
      title: t.useCases.tasks.title,
      description: t.useCases.tasks.description,
      icon: 'tabler:checkbox',
    },
    {
      title: t.useCases.dashboards.title,
      description: t.useCases.dashboards.description,
      icon: 'tabler:chart-bar',
    },
    {
      title: t.useCases.ecommerce.title,
      description: t.useCases.ecommerce.description,
      icon: 'tabler:shopping-cart',
    },
    {
      title: t.useCases.internal.title,
      description: t.useCases.internal.description,
      icon: 'tabler:tool',
    },
    {
      title: t.useCases.ai.title,
      description: t.useCases.ai.description,
      icon: 'tabler:robot',
    },
    {
      title: t.useCases.saas.title,
      description: t.useCases.saas.description,
      icon: 'tabler:flask',
    },
    {
      title: t.useCases.social.title,
      description: t.useCases.social.description,
      icon: 'tabler:users',
    },
    {
      title: t.useCases.content.title,
      description: t.useCases.content.description,
      icon: 'tabler:file-text',
    },
    {
      title: t.useCases.productivity.title,
      description: t.useCases.productivity.description,
      icon: 'tabler:clock',
    },
  ]}
>
  <Fragment slot="bg">
    <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
  </Fragment>
</Features2>

<!-- ===================== STATS ===================== -->
<Stats
  stats={[
    { title: t.stats.appsBuilt, amount: t.stats.appsAmount },
    { title: t.stats.developers, amount: t.stats.devsAmount },
    { title: t.stats.components, amount: t.stats.componentsAmount },
    { title: t.stats.deployTime, amount: t.stats.deployAmount },
  ]}
/>

<!-- ===================== FAQ ===================== -->
<FAQs
  id="faq"
  title={t.faq.title}
  subtitle={t.faq.subtitle}
  tagline={t.faq.tagline}
  classes={{ container: 'max-w-6xl' }}
  items={[
    {
      title: t.faq.q1.title,
      description: t.faq.q1.description,
    },
    {
      title: t.faq.q2.title,
      description: t.faq.q2.description,
    },
    {
      title: t.faq.q3.title,
      description: t.faq.q3.description,
    },
    {
      title: t.faq.q4.title,
      description: t.faq.q4.description,
    },
    {
      title: t.faq.q5.title,
      description: t.faq.q5.description,
    },
    {
      title: t.faq.q6.title,
      description: t.faq.q6.description,
    },
    {
      title: t.faq.q7.title,
      description: t.faq.q7.description,
    },
    {
      title: t.faq.q8.title,
      description: t.faq.q8.description,
    },
  ]}
/>

<!-- ===================== PRICING ===================== -->
<Pricing
  id="pricing"
  title={t.pricing.title}
  subtitle={t.pricing.subtitle}
  prices={[
    {
      title: t.pricing.starterTitle,
      subtitle: t.pricing.starterSubtitle,
      price: 19,
      period: t.pricing.perMonth,
      items: [
        { description: '150 AI credits / month' },
        { description: 'Live sandbox preview' },
        { description: 'Download code as ZIP' },
        { description: 'React 19 + TypeScript + Tailwind' },
        { description: 'Community support' },
      ],
      callToAction: {
        target: '_blank',
        text: t.pricing.starterCta,
        href: 'https://app.borchani.com/signup?plan=starter',
      },
    },
    {
      title: t.pricing.proTitle,
      subtitle: t.pricing.proSubtitle,
      price: 49,
      period: t.pricing.perMonth,
      items: [
        { description: '500 AI credits / month' },
        { description: 'One-click GitHub export' },
        { description: 'Custom domain deployment' },
        { description: 'Priority build queue' },
        { description: 'TypeScript SDK access' },
        { description: 'Email support (< 24 h)' },
      ],
      callToAction: {
        target: '_blank',
        text: t.pricing.proCta,
        href: 'https://app.borchani.com/signup?plan=pro',
      },
      hasRibbon: true,
      ribbonTitle: t.pricing.proRibbon,
    },
    {
      title: t.pricing.businessTitle,
      subtitle: t.pricing.businessSubtitle,
      price: 149,
      period: t.pricing.perMonth,
      items: [
        { description: '2,000 AI credits / month' },
        { description: 'Up to 10 seats included' },
        { description: 'Shared workspaces & build history' },
        { description: 'REST API + webhooks' },
        { description: 'SSO & admin controls' },
        { description: 'Priority chat & email support' },
      ],
      callToAction: {
        target: '_blank',
        text: t.pricing.businessCta,
        href: 'https://app.borchani.com/signup?plan=business',
      },
    },
  ]}
/>

<!-- ===================== CONTACT CTA ===================== -->
<Steps2
  title={t.contact.title}
  subtitle={t.contact.subtitle}
  callToAction={{
    text: t.contact.cta,
    href: `${prefix}/contact`,
  }}
  items={[
    {
      title: t.contact.email,
      description: t.contact.emailHandle,
      icon: 'tabler:mail',
    },
    {
      title: t.contact.follow,
      description: t.contact.followHandle,
      icon: 'tabler:brand-x',
    },
    {
      title: t.contact.discord,
      description: t.contact.discordHandle,
      icon: 'tabler:brand-discord',
    },
  ]}
/>

<!-- ===================== BLOG ===================== -->
<BlogLatestPosts
  id="blog"
  title={t.blog.title}
  information={t.blog.subtitle}
>
  <Fragment slot="bg">
    <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
  </Fragment>
</BlogLatestPosts>

<!-- ===================== JSON-LD Structured Data ===================== -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://borchani.com/#website",
      "url": "https://borchani.com/",
      "name": "Borchani",
