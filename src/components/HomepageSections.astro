          }
        },
        {
          "@type": "Question",
          "name": "What tech stack do generated apps use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "All apps are built with React 19, TypeScript, Vite, Tailwind CSS, and shadcn/ui components. The stack is modern, well-documented, and widely adopted."
          }
