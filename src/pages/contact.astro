---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact Borchani — Get Help or Talk to Sales',
  description:
    'Questions about your account, billing, or a custom plan? Reach out — we reply within one business day.',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText tagline="Contact" title="We're real people. Just ask." />

  <ContactUs
    id="form"
    title="Send us a message"
    subtitle="Check the FAQ first — you might find your answer faster there. If not, fill in the form and we'll get back to you."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Your name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Work email',
      },
    ]}
    textarea={{
      label: 'How can we help?',
    }}
    disclaimer={{
      label:
        'By submitting this form you agree to our Privacy Policy. We will only use your information to respond to your inquiry.',
    }}
    description="We typically reply within one business day."
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Other ways to reach us"
    items={[
      {
        title: 'General questions',
        description:
          'Account access, billing, plan changes, or anything else about using Borchani — drop us an email or use the form above.',
      },
      {
        title: 'Enterprise & sales',
        description:
          'Looking for a custom plan, higher limits, SLA, or a dedicated account manager? Let us know and we will put together an offer.',
      },
      {
        title: 'Technical issues',
        description:
          'If your build is failing, something looks broken, or the generated code has a persistent issue — describe it here and we will dig in.',
      },
      {
        title: 'Discord community',
        description: 'discord.gg/borchani',
        icon: 'tabler:brand-discord',
      },
      {
        title: 'Email',
        description: 'hello@borchani.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Based in',
        description: 'San Francisco, CA — remote team worldwide',
        icon: 'tabler:map-pin',
      },
    ]}
  />
</Layout>
