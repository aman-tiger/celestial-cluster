---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About Borchani — AI App Builder',
  description:
    'We built Borchani because setting up a new project was eating too much time. Learn about the team, our values, and why we obsess over developer experience.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="About us"
    image={{
      src: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Borchani team working',
    }}
  >
    <Fragment slot="title">
      We got tired of setting up projects from scratch.<br />
      <span class="text-accent dark:text-white">So we built Borchani.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Borchani started with a simple frustration — too much time spent on boilerplate, config, and scaffolding
      before a single line of real logic got written. We built an AI that handles all of that so developers can
      spend their time on things that actually matter. Today, thousands of developers use Borchani to turn ideas
      into running applications in minutes.
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Borchani by the numbers"
    stats={[
      { title: 'Apps built', amount: '10K+' },
      { title: 'Developers', amount: '3K+' },
      { title: 'UI components', amount: '50+' },
      { title: 'Avg. build time', amount: '< 5 min' },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="What people build with Borchani"
    subtitle="We designed Borchani to be flexible enough for almost any web application — here is what our users ship most often."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Internal tools',
        description:
          'Admin panels, data dashboards, approval workflows — the stuff that keeps companies running but nobody wants to spend weeks building.',
        icon: 'tabler:tool',
      },
      {
        title: 'SaaS prototypes',
        description:
          'Go from idea to clickable, deployable MVP in hours. Validate before you invest months in development.',
        icon: 'tabler:flask',
      },
      {
        title: 'Client projects',
        description:
          'Agencies and freelancers use Borchani to deliver projects faster without cutting corners on code quality.',
        icon: 'tabler:briefcase',
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'E-commerce UIs',
        description:
          'Product catalogs, shopping carts, checkout flows — Borchani generates complete, responsive interfaces.',
        icon: 'tabler:shopping-cart',
      },
      {
        title: 'AI-powered apps',
        description:
          'Chat interfaces, prompt playgrounds, AI dashboards. Borchani handles the plumbing so you focus on the intelligence layer.',
        icon: 'tabler:robot',
      },
      {
        title: 'Data apps',
        description:
          'Charts, filterable tables, KPI boards. Give Borchani your data shape and it builds the full interactive interface.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Productivity tools',
        description:
          'Kanban boards, habit trackers, note-taking apps, timers — personal tools that would take a weekend to write by hand.',
        icon: 'tabler:checkbox',
      },
      {
        title: 'Social features',
        description:
          'Comment threads, feeds, real-time chat. Borchani generates complete WebSocket-backed social components.',
        icon: 'tabler:users',
      },
      {
        title: 'Landing pages',
        description:
          'Fast, SEO-ready marketing pages with clear CTAs. No builder lock-in — just clean Astro or React code you own.',
        icon: 'tabler:layout',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Developer working with Borchani',
    }}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="What we stand for"
    subtitle="Three things we come back to whenever we make a product decision."
    items={[
      {
        title: 'Developer experience first',
        description:
          'We are developers ourselves. If something feels annoying to use, we fix it. Generated code should be as readable and maintainable as code written by hand.',
      },
      {
        title: 'Ship fast, fix fast',
        description:
          'We release updates every week. When something breaks, we fix it the same day. Speed is part of how we operate — not just what we sell.',
      },
      {
        title: 'You own everything',
        description:
          'Your data, your code, your apps. We do not lock you in. Export at any time, deploy anywhere, modify freely. No strings attached.',
      },
    ]}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="A few things we're proud of"
    subtitle="We're a small team, but the product speaks for itself."
    isReversed={true}
    callToAction={{
      text: 'Start building',
      href: 'https://app.borchani.com/signup',
    }}
    items={[
      {
        title: 'Used in 40+ countries',
        description:
          'Developers from San Francisco to Singapore use Borchani to ship products faster. We did not expect the adoption to spread this quickly.',
        icon: 'tabler:globe',
      },
      {
        title: 'Consistently rated 4.9/5',
        description:
          'Across review platforms and user surveys, the feedback has been clear: the builder works, the code is clean, and the support is fast.',
        icon: 'tabler:message-star',
      },
      {
        title: 'Featured in multiple developer publications',
        description:
          'Borchani has been covered in several developer newsletters and tech blogs as a standout tool for AI-assisted development.',
        icon: 'tabler:award',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Where we are"
    tagline="Find us"
    columns={4}
    items={[
      {
        title: 'Remote first',
        description: 'Our core team works fully remote, across multiple time zones.',
      },
      {
        title: 'San Francisco',
        description: 'Company registered in California, USA.',
      },
      {
        title: 'Community',
        description: 'Discord · GitHub · X (Twitter)',
      },
      {
        title: 'Available 24/7',
        description: 'App uptime monitored around the clock.',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Get in touch"
    tagline="Contact us"
    columns={2}
    items={[
      {
        title: 'Chat with us',
        description:
          'Join our Discord community to get help from the team and other Borchani users. Usually answered within an hour during business hours.',
        icon: 'tabler:brand-discord',
      },
      {
        title: 'Email us',
        description:
          'Reach out to hello@borchani.com for billing questions, enterprise inquiries, or anything else. We reply within one business day.',
        icon: 'tabler:mail',
      },
    ]}
  />

  <!-- JSON-LD Organization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Borchani",
    "url": "https://borchani.com",
    "logo": "https://borchani.com/favicon.svg",
    "foundingDate": "2024",
    "description": "Borchani is an AI-powered app builder that generates production-ready full-stack web applications from natural language descriptions.",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "hello@borchani.com",
      "contactType": "customer support"
    },
    "sameAs": [
      "https://x.com/borchani"
    ]
  })} />
</Layout>
