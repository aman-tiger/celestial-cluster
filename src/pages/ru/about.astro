---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'О нас - Borchani AI App Builder',
  description:
    'Мы создали Borchani, потому что устали от бесконечной настройки проектов. Узнайте о команде, наших ценностях и почему мы одержимы опытом разработчика.',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="О нас"
    image={{
      src: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=2070&q=80',
      alt: 'Команда Borchani за работой',
    }}
  >
    <Fragment slot="title">
      Мы устали тратить время на настройку проектов с нуля.<br />
      <span class="text-accent dark:text-white">Поэтому мы создали Borchani.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Borchani появился из простого разочарования - слишком много времени уходило на шаблонный код, конфигурацию и scaffolding,
      прежде чем удавалось написать хоть строчку реальной логики. Мы создали ИИ, который берёт всё это на себя,
      чтобы разработчики могли тратить время на то, что действительно важно. Сегодня тысячи разработчиков используют Borchani,
      чтобы превращать идеи в работающие приложения за минуты.
    </Fragment>
  </Hero>

  <Stats
    title="Borchani в цифрах"
    stats={[
      { title: 'Создано приложений', amount: '10 000+' },
      { title: 'Разработчиков', amount: '3 000+' },
      { title: 'UI-компонентов', amount: '50+' },
      { title: 'Среднее время сборки', amount: '< 5 мин' },
    ]}
  />

  <Features3
    title="Что создают с Borchani"
    subtitle="Мы разработали Borchani достаточно гибким для почти любого веб-приложения - вот что наши пользователи запускают чаще всего."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Внутренние инструменты',
        description:
          'Панели администратора, дашборды данных, рабочие процессы согласования - всё то, что держит компании на плаву, но никто не хочет тратить недели на разработку.',
        icon: 'tabler:tool',
      },
      {
        title: 'SaaS-прототипы',
        description:
          'От идеи до кликабельного, готового к деплою MVP за часы. Валидируйте идею, прежде чем вкладывать месяцы в разработку.',
        icon: 'tabler:flask',
      },
      {
        title: 'Клиентские проекты',
        description:
          'Агентства и фрилансеры используют Borchani для более быстрой сдачи проектов без потери качества кода.',
        icon: 'tabler:briefcase',
      },
    ]}
  />

  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'E-commerce интерфейсы',
        description:
          'Каталоги товаров, корзины, процессы оформления заказа - Borchani генерирует полные адаптивные интерфейсы.',
        icon: 'tabler:shopping-cart',
      },
      {
        title: 'Приложения на базе ИИ',
        description:
          'Чат-интерфейсы, площадки для промптов, дашборды ИИ. Borchani берёт на себя техническую часть, а вы сосредотачиваетесь на интеллектуальном слое.',
        icon: 'tabler:robot',
      },
      {
        title: 'Приложения для данных',
        description:
          'Графики, фильтруемые таблицы, KPI-доски. Опишите Borchani структуру данных, и он создаст полный интерактивный интерфейс.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Инструменты продуктивности',
        description:
          'Канбан-доски, трекеры привычек, приложения для заметок - личные инструменты, которые вручную заняли бы целые выходные.',
        icon: 'tabler:checkbox',
      },
      {
        title: 'Социальные функции',
        description:
          'Ветки комментариев, ленты, чат в реальном времени. Borchani генерирует полные социальные компоненты с поддержкой WebSocket.',
        icon: 'tabler:users',
      },
      {
        title: 'Лендинги',
        description:
          'Быстрые, SEO-готовые маркетинговые страницы с чёткими CTA. Без привязки к конструктору - только чистый код на Astro или React, который принадлежит вам.',
        icon: 'tabler:layout',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=1740&q=80',
      alt: 'Разработчик работает с Borchani',
    }}
  />

  <Steps2
    title="Наши ценности"
    subtitle="Три принципа, к которым мы возвращаемся при каждом продуктовом решении."
    items={[
      {
        title: 'Опыт разработчика на первом месте',
        description:
          'Мы сами разработчики. Если что-то раздражает в использовании, мы это исправляем. Сгенерированный код должен быть таким же читаемым и поддерживаемым, как написанный вручную.',
      },
      {
        title: 'Быстро запускай, быстро исправляй',
        description:
          'Мы выпускаем обновления каждую неделю. Когда что-то ломается, мы исправляем это в тот же день. Скорость - часть нашей работы, а не только того, что мы продаём.',
      },
      {
        title: 'Вам принадлежит всё',
        description:
          'Ваши данные, ваш код, ваши приложения. Мы не привязываем вас к платформе. Экспортируйте в любое время, деплойте где угодно, изменяйте свободно. Без оговорок.',
      },
    ]}
  />

  <Steps2
    title="Чем мы гордимся"
    subtitle="Небольшая команда, но продукт говорит сам за себя."
    isReversed={true}
    callToAction={{
      text: 'Начать создавать',
      href: 'https://app.borchani.com/api/auth/oauth/google',
    }}
    items={[
      {
        title: 'Используется в 40+ странах',
        description:
          'Разработчики от Москвы до Сингапура используют Borchani для более быстрого запуска продуктов. Мы не ожидали, что распространение произойдёт так быстро.',
        icon: 'tabler:globe',
      },
      {
        title: 'Стабильный рейтинг 4.9/5',
        description:
          'На всех платформах отзывов и в опросах пользователей обратная связь однозначная: конструктор работает, код чистый, поддержка быстрая.',
        icon: 'tabler:message-star',
      },
      {
        title: 'Упоминания в профессиональных изданиях',
        description:
          'Borchani был отмечен в нескольких рассылках для разработчиков и технических блогах как выдающийся инструмент для разработки с поддержкой ИИ.',
        icon: 'tabler:award',
      },
    ]}
  />

  <Features2
    title="Где мы находимся"
    tagline="Найдите нас"
    columns={4}
    items={[
      {
        title: 'Удалённая команда',
        description: 'Наша основная команда работает полностью удалённо, в разных часовых поясах.',
      },
      {
        title: 'Сан-Франциско',
        description: 'Компания зарегистрирована в Калифорнии, США.',
      },
      {
        title: 'Сообщество',
        description: 'Discord · GitHub · X (Twitter)',
      },
      {
        title: 'Доступны 24/7',
        description: 'Работа приложения отслеживается круглосуточно.',
      },
    ]}
  />

  <Features2
    title="Свяжитесь с нами"
    tagline="Контакты"
    columns={2}
    items={[
      {
        title: 'Напишите нам в чате',
        description:
          'Присоединяйтесь к нашему Discord-сообществу, чтобы получить помощь от команды и других пользователей Borchani. Обычно отвечаем в течение часа в рабочее время.',
        icon: 'tabler:brand-discord',
      },
      {
        title: 'Напишите по email',
        description:
          'Обращайтесь на hello@borchani.com по вопросам оплаты, корпоративным запросам или любым другим. Отвечаем в течение одного рабочего дня.',
        icon: 'tabler:mail',
      },
    ]}
  />
</Layout>
