          "billingIncrement": "P1M"
        }
      ],
      "featureList": [
        "AI code generation",
        "Live sandbox preview",
        "React 19 + TypeScript + Tailwind CSS",
        "One-click deployment",
        "GitHub export",
        "TypeScript SDK",
        "Real-time collaborative editing",
        "Enterprise-grade security"
      ],
      "screenshot": "https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&w=1200&q=80",
